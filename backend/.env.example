# Environment Variables — copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/civicsense

# JWT Secrets — use long, random strings in production
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary — for image/video uploads (optional; local uploads used as fallback)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — URL of the frontend application
CLIENT_URL=http://localhost:3000

# Frontend URL — used in email links
FRONTEND_URL=http://localhost:3000

# SMTP / Email — for OTP and notification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="CivicSense" <your_email@gmail.com>
